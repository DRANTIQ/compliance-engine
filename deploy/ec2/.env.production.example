# Copy to deploy/ec2/.env on the EC2 host — never commit.
# chmod 600 .env

DATABASE_URL=postgresql://USER:PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require

REDIS_URL=redis://redis:6379/0

S3_BUCKET=steampipe-data-storage
S3_REGION=us-east-1
S3_PREFIX=platform-v2
USE_LOCAL_STORAGE=false

COLLECT_QUEUE_KEY=platform:collect.aws
COLLECT_AZURE_QUEUE_KEY=platform:collect.azure
PLATFORM_EVENTS_KEY=platform:events
POLICY_QUEUE_KEY=platform:policy.evaluate

API_HOST=0.0.0.0
API_PORT=8090
CORS_ORIGINS=https://app.drantiq.ai,https://admin.drantiq.ai

LOG_LEVEL=INFO
LOG_FORMAT=json
DEV_TENANT_HEADER_AUTH=false

OIDC_ENABLED=true
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
OIDC_AUDIENCE=authenticated

EXTERNAL_ID_ENCRYPTION_KEY=

# Prefer EC2 instance IAM role for collector/API S3 access (leave blank when using IRSA/instance profile)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

COLLECTOR_MOCK=false
