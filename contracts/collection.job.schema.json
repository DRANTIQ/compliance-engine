{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "collection.job.schema.json",
  "title": "CollectionJob",
  "description": "Work unit for platform collect queues (AWS or Azure). Jobs omit event envelope fields.",
  "oneOf": [
    { "$ref": "#/$defs/AwsCollectionJob" },
    { "$ref": "#/$defs/AzureCollectionJob" }
  ],
  "$defs": {
    "CollectionJobBase": {
      "type": "object",
      "required": [
        "job_id",
        "scan_id",
        "tenant_id",
        "integration_id",
        "collection_run_id",
        "account_id",
        "regions",
        "s3_bucket",
        "s3_prefix"
      ],
      "properties": {
        "job_id": { "type": "string", "format": "uuid" },
        "scan_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "format": "uuid" },
        "integration_id": { "type": "string", "format": "uuid" },
        "collection_run_id": { "type": "string", "format": "uuid" },
        "trace_id": { "type": "string", "format": "uuid" },
        "account_id": { "type": "string", "minLength": 1 },
        "regions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "s3_bucket": { "type": "string", "minLength": 1 },
        "s3_prefix": { "type": "string", "minLength": 1 },
        "plugins": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "AwsCollectionJob": {
      "allOf": [
        { "$ref": "#/$defs/CollectionJobBase" },
        {
          "type": "object",
          "properties": {
            "provider": { "const": "aws" },
            "account_id": { "type": "string", "pattern": "^[0-9]{12}$" },
            "role_arn": { "type": "string", "minLength": 1 },
            "external_id": { "type": "string", "minLength": 1 },
            "plugins": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^aws\\."
              },
              "minItems": 1
            }
          },
          "required": ["role_arn", "external_id"]
        }
      ]
    },
    "AzureCollectionJob": {
      "allOf": [
        { "$ref": "#/$defs/CollectionJobBase" },
        {
          "type": "object",
          "properties": {
            "provider": { "const": "azure" },
            "account_id": {
              "type": "string",
              "description": "Azure subscription id",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            },
            "azure_tenant_id": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            },
            "azure_client_id": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            },
            "azure_client_secret": { "type": "string", "minLength": 1 },
            "plugins": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^azure\\."
              },
              "minItems": 1
            }
          },
          "required": ["provider", "azure_tenant_id", "azure_client_id", "azure_client_secret"]
        }
      ]
    }
  }
}
